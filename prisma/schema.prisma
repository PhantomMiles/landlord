// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  LANDLORD
  TENANT
  VENDOR
  ADMIN
}

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  name                 String
  passwordHash         String?
  role                 Role      @default(TENANT)
  phone                String?
  isBvnVerified        Boolean   @default(false)
  isGovIdVerified      Boolean   @default(false)
  isBiometricVerified  Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  properties           Property[]           @relation("LandlordProperties")
  leases               Lease[]              @relation("TenantLeases")
  maintenanceRequests  MaintenanceRequest[] @relation("TenantRequests")
  assignedMaintenance  MaintenanceRequest[] @relation("VendorAssignments")
  tenantScore          TenantScore?
  payments             Payment[]            @relation("UserPayments")
  rentShield           RentShield?
}

model Property {
  id          String   @id @default(uuid())
  name        String
  address     String
  city        String?
  state       String?
  type        String?
  landlordId  String
  landlord    User     @relation("LandlordProperties", fields: [landlordId], references: [id])
  units       Unit[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Unit {
  id                  String               @id @default(uuid())
  propertyId          String
  property            Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unitNumber          String
  rentAmount          Float
  status              String               @default("VACANT")
  leases              Lease[]
  maintenanceRequests MaintenanceRequest[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model Lease {
  id             String    @id @default(uuid())
  tenantId       String
  tenant         User      @relation("TenantLeases", fields: [tenantId], references: [id])
  unitId         String
  unit           Unit      @relation(fields: [unitId], references: [id])
  startDate      DateTime
  endDate        DateTime
  status         String    @default("ACTIVE")
  rentAmount     Float
  autoPaySetup   Boolean   @default(false)
  payments       Payment[]
  escrow         Escrow?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model RentShield {
  id                 String    @id @default(uuid())
  tenantId           String    @unique
  tenant             User      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  targetAmount       Float
  currentBalance     Float     @default(0)
  contributionAmount Float
  frequency          String    @default("MONTHLY")
  isActive           Boolean   @default(true)
  shieldLevel        String    @default("NONE")
  badgeEarned        Boolean   @default(false)
  streakMonths       Int       @default(0)
  autoDeduct         Boolean   @default(false)
  lastContribution   DateTime?
  nextContribution   DateTime?
  contributions      RentShieldContribution[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model RentShieldContribution {
  id            String     @id @default(uuid())
  rentShieldId  String
  rentShield    RentShield @relation(fields: [rentShieldId], references: [id], onDelete: Cascade)
  amount        Float
  status        String     @default("COMPLETED")
  note          String?
  createdAt     DateTime   @default(now())
}

model TenantScore {
  id               String   @id @default(uuid())
  tenantId         String   @unique
  tenant           User     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  identityScore    Float    @default(0)
  financialScore   Float    @default(0)
  behavioralScore  Float    @default(0)
  engagementScore  Float    @default(0)
  totalScore       Float    @default(0)
  paymentStreaks   Int      @default(0)
  platformActivity Int      @default(0)
  lastUpdated      DateTime @updatedAt
  createdAt        DateTime @default(now())
}

enum PaymentType {
  RENT
  MAINTENANCE
  ESCROW
  FEE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Payment {
  id             String        @id @default(uuid())
  amount         Float
  type           PaymentType
  status         PaymentStatus @default(PENDING)
  reference      String?       @unique
  tenantId       String
  tenant         User          @relation("UserPayments", fields: [tenantId], references: [id])
  leaseId        String?
  lease          Lease?        @relation(fields: [leaseId], references: [id])
  platformFee    Float         @default(0)
  maintenanceFee Float         @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Escrow {
  id              String   @id @default(uuid())
  leaseId         String   @unique
  lease           Lease    @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  amount          Float
  status          String   @default("HELD")
  inspectionNotes String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MaintenanceRequest {
  id          String   @id @default(uuid())
  description String
  status      String   @default("OPEN")
  cost        Float?
  unitId      String
  unit        Unit     @relation(fields: [unitId], references: [id])
  tenantId    String
  tenant      User     @relation("TenantRequests", fields: [tenantId], references: [id])
  vendorId    String?
  vendor      User?    @relation("VendorAssignments", fields: [vendorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
